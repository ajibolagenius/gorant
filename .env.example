# --- Turso / libSQL demo database ---
# Leave these unset for local development: the app falls back to an embedded
# SQLite file at ./local.db (run `npm run db:setup` to create and seed it).
#
# For production (Vercel), create a free Turso database and set both values:
#   1. Install the CLI:      curl -sSfL https://get.tur.so/install.sh | bash
#   2. Create a database:    turso db create gorant
#   3. Get the URL:          turso db show gorant --url
#   4. Mint a token:         turso db tokens create gorant
# Then add these in Vercel Project Settings → Environment Variables:
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# --- Site URL (used by SEO / RSS / OG) ---
NEXT_PUBLIC_SITE_URL=https://gorant.vercel.app

# --- Nightly demo reset cron ---
# Secret that authorizes the /api/cron/reset-demo endpoint. Vercel Cron attaches
# this automatically as `Authorization: Bearer $CRON_SECRET`. Generate one with:
#   openssl rand -hex 32
# Set it in Vercel → Environment Variables (Production). Without it, the reset
# endpoint refuses all requests (fails closed).
CRON_SECRET=your-random-secret

# --- Legacy Supabase (optional) ---
# No longer used by the demo feed. Only set these if you run the Supabase
# Postgres path in supabase/migrations for local development.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
