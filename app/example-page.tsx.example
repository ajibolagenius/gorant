import { Metadata } from 'next';
import { getPageMetadata } from '@/lib/seo/metadata';

// Generate metadata for this page
export const generateMetadata = (): Metadata => {
  return getPageMetadata(
    {
      title: 'Example Page | Rant',
      description: 'This is an example page showing how to use the SEO metadata system.',
      keywords: ['example', 'seo', 'metadata', 'next.js'],
      ogType: 'website',
    },
    '/example-page'
  );
};

export default function ExamplePage() {
  return (
    <div className="container mx-auto py-8">
      <h1 className="text-3xl font-bold mb-4">Example Page</h1>
      <p className="mb-4">
        This page demonstrates how to use the SEO metadata system in Next.js pages.
      </p>
    </div>
  );
}
